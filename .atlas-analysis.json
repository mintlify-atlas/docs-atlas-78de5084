  "keyFeatures": [
    "Multi-language support (Spanish, English, Valencian)",
    "Sanity CMS integration with localized content",
    "Server-side form handling with email notifications",
    "Animated components using GSAP and Lenis",
    "Responsive design with custom SCSS styling",
    "Interactive menu (Carta) with allergen information",
    "Location finder with map integration",
    "Job offers management system"
  ],
  "publicApiSurface": [
    "submitCvForm - Server action for job application submissions",
    "submitContactForm - Server action for contact form submissions",
    "subscribeToClub - Server action for newsletter subscriptions",
    "getFrontPageQuery - Query for home page content",
    "getHistoriaPageQuery - Query for history page content",
    "getContactPageQuery - Query for contact page content",
    "getCartaPageQuery - Query for menu content",
    "getPizzeriasPageQuery - Query for locations content",
    "getTrabajaConNosotrosPageQuery - Query for jobs page content",
    "localizedField - Helper for fetching localized fields from Sanity",
    "localizedArray - Helper for fetching localized arrays from Sanity",
    "getLangFromUrl - Utility to extract language from URL",
    "useTranslations - Utility to get translation function for a language"
  ]
}
